# LLM Provider API Keys
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Server Config
PORT=4000
NODE_ENV=production
BOOTSTRAP_ADMIN_TOKEN=change-this-to-a-long-random-token
BOOTSTRAP_ADMIN_WORKSPACE_ID=default

# Web (Next.js) — server-side gateway URL for /api/gateway/* (local dev: http://localhost:4000)
# Docker Compose sets NEXT_PUBLIC_API_BASE_URL=http://api:4000 for the web container.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# Dev-only: allows x-workspace-id/x-user-id fallback auth (ignored in production)
# ALLOW_LEGACY_HEADER_AUTH=false

# Database (default: ./data/gateway.db)
DATABASE_PATH=./data/gateway.db
# PostgreSQL runtime is intentionally disabled in this release.
# If DATABASE_URL is set, server startup will fail closed.
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_gateway

# Optional: enable cross-provider fallback only if you add provider adapters.
# Disabled by default to avoid payload mismatch issues.
# ENABLE_CROSS_PROVIDER_FALLBACK=false
